# AI Employee — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env to Git.
#
# Local: cp .env.example .env
# Cloud: set these in PM2 ecosystem or /etc/environment

# ── Agent identity ────────────────────────────────────────────────────────────
AGENT_ID=local-pc           # local-pc | cloud-vm-1
REPO_DIR=/mnt/c/Users/anzal/Desktop/AN-hack-0

# ── Vault sync ────────────────────────────────────────────────────────────────
GIT_BRANCH=master
SYNC_INTERVAL=300           # seconds between vault syncs (cloud)
WATCH_INTERVAL=60           # seconds between local orchestrator cycles

# ── Odoo (Gold Tier) ──────────────────────────────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=admin         # CHANGE THIS after first Odoo login

# ── Cloud orchestrator ────────────────────────────────────────────────────────
MAX_CLAIMS=10               # max items cloud_orchestrator claims per run

# ── Gmail (NEVER commit token files — only reference paths here) ──────────────
# Tokens are stored as files: gmail_token.json, gmail_send_token.json
# Upload to cloud manually: scp -i hackathon.pem gmail_token.json ubuntu@IP:~/personal-ai-employee/
